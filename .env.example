# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://calflow:calflow@localhost:5432/calflow

# ─── Anthropic Claude API (AI 투자 추천 기능) ─────────────────────────────────
# Claude API 키 발급: https://console.anthropic.com
# 미설정 시 목 데이터로 동작 (개발·테스트용)
